generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Agriculteur Agriculteur?
  ConsommateurCommercant ConsommateurCommercant?
  avisLaisses            Avis[]                   @relation("AvisAuteur")
  avisRecus              Avis[]                   @relation("AvisCible")
}

model Agriculteur {
    id  Int   @id @default(autoincrement())
    userId  Int  @unique
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
    nom  String
    prenom  String
    localisation  String
    available Boolean  @default(true)
    numeroAgriculmobile String 
    numeroAgriculwhatsapp String
    produit String []
    genre String
    age String ?
    photoUrl String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
}

model ConsommateurCommercant {
  idC Int @id @default(autoincrement())
  userId Int @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  nomC String
  prenomC String
  localisationC String
  numeroMobile String
  numeroWhatsapp String
  demande String []
  genre String
  age String ?
  photoUrl String?
  metier String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 

model Avis {
  id            Int      @id @default(autoincrement())
  note          Int      
  commentaire   String?  
  auteurId      Int
  auteur        User     @relation("AvisAuteur", fields: [auteurId], references: [id], onDelete: Cascade)
  cibleId       Int
  cible         User     @relation("AvisCible", fields: [cibleId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  @@unique([auteurId, cibleId]) 
}